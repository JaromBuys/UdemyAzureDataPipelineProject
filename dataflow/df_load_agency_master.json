{
	"name": "df_load_agency_master",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "agency_master",
						"type": "DatasetReference"
					},
					"name": "SrcAgencyMaster"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "snk_agency_md",
						"type": "DatasetReference"
					},
					"name": "SnkAgencyMaster"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          AgencyID as string,",
				"          AgencyName as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> SrcAgencyMaster",
				"SrcAgencyMaster sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     truncate: true,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SnkAgencyMaster"
			]
		}
	}
}