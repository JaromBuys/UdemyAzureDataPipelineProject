{
	"name": "df_load_emp_master",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "employee_master",
						"type": "DatasetReference"
					},
					"name": "SrcEmpMaster"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "snk_emp_master",
						"type": "DatasetReference"
					},
					"name": "SnkEmpMaster"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          EmployeeID as string,",
				"          LastName as string,",
				"          FirstName as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> SrcEmpMaster",
				"SrcEmpMaster sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     truncate: true,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SnkEmpMaster"
			]
		}
	}
}