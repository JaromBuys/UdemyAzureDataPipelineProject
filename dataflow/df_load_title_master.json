{
	"name": "df_load_title_master",
	"properties": {
		"type": "MappingDataFlow",
		"typeProperties": {
			"sources": [
				{
					"dataset": {
						"referenceName": "title_master",
						"type": "DatasetReference"
					},
					"name": "SrcTitleMaster"
				}
			],
			"sinks": [
				{
					"dataset": {
						"referenceName": "snk_title_md",
						"type": "DatasetReference"
					},
					"name": "SnkTitleMaster"
				}
			],
			"transformations": [],
			"scriptLines": [
				"source(output(",
				"          TitleCode as string,",
				"          TitleDescription as string",
				"     ),",
				"     allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     ignoreNoFilesFound: false) ~> SrcTitleMaster",
				"SrcTitleMaster sink(allowSchemaDrift: true,",
				"     validateSchema: false,",
				"     truncate: true,",
				"     umask: 0022,",
				"     preCommands: [],",
				"     postCommands: [],",
				"     skipDuplicateMapInputs: true,",
				"     skipDuplicateMapOutputs: true) ~> SnkTitleMaster"
			]
		}
	}
}